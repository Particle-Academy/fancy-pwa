{
  "name": "@particle-academy/fancy-pwa",
  "version": "0.1.2",
  "description": "Lean, framework-agnostic, SSR-safe PWA layer for the Fancy UI suite — install prompt, online/offline, a Workbox-free service-worker toolkit, a Vite plugin, and update detection composed on fancy-app-update.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Particle-Academy/fancy-pwa.git"
  },
  "homepage": "https://github.com/Particle-Academy/fancy-pwa#readme",
  "bugs": "https://github.com/Particle-Academy/fancy-pwa/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite/index.d.ts",
        "default": "./dist/vite.js"
      },
      "require": {
        "types": "./dist/vite/index.d.cts",
        "default": "./dist/vite.cjs"
      }
    },
    "./sw": {
      "import": {
        "types": "./dist/sw/index.d.ts",
        "default": "./dist/sw.js"
      },
      "require": {
        "types": "./dist/sw/index.d.cts",
        "default": "./dist/sw.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "react",
    "pwa",
    "service-worker",
    "vite-plugin",
    "offline",
    "install-prompt",
    "ssr",
    "fancy"
  ],
  "peerDependencies": {
    "@particle-academy/fancy-app-update": ">=0.1",
    "@particle-academy/fancy-auto-common": ">=0.1",
    "@particle-academy/react-fancy": ">=4",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "@particle-academy/react-fancy": {
      "optional": true
    },
    "@particle-academy/fancy-auto-common": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@particle-academy/fancy-app-update": "^0.1.0",
    "@particle-academy/fancy-auto-common": "^0.1.0",
    "@particle-academy/react-fancy": "^4.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.21",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vite": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ]
}
